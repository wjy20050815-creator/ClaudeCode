# Vault 路径注册表（模板）— 所有 vault 路径的唯一定义处（router 模式）
#
# 用法：
#   1. 复制本文件为 vault.paths.env，把下面的路径改成你自己的
#   2. shell：source vault.paths.env（支持 ${VAR} 展开）
#   3. python：tools/vault_paths.py 的 vault_path("KEY")
#   4. skill（markdown 指令）：先读 vault.paths.env 解析路径，不要硬编码
#
# 真实的 vault.paths.env 已被 .gitignore 排除（含个人目录名），仅本模板入库。
# vault 重组时只改 vault.paths.env，然后跑 tools/vault_index_sync.py --check 验证。

VAULT_ROOT="$HOME/Documents/Obsidian Vault"

# 治理基础设施
VAULT_INDEX="${VAULT_ROOT}/index.md"
VAULT_LOG="${VAULT_ROOT}/log.md"
VAULT_MANUAL="${VAULT_ROOT}/_CLAUDE.md"
VAULT_ATTACHMENTS="${VAULT_ROOT}/_attachments"

# agent 写入点（按需改成你自己的文件夹名）
VAULT_BRIEF_DIR="${VAULT_ROOT}/DailyBrief"
VAULT_INBOX="${VAULT_ROOT}/Inbox"
VAULT_PAPERS="${VAULT_ROOT}/Papers"
VAULT_CONCEPTS="${VAULT_ROOT}/Concepts"

# 蒸馏系统（可选；用不到的 agent 留空即可）
VAULT_SHUKATSU_DISTILL="${VAULT_ROOT}/Distill"
VAULT_SHUKATSU_SOZAI_YT="${VAULT_SHUKATSU_DISTILL}/Sources/YouTube"
VAULT_SHUKATSU_SOZAI_WEB="${VAULT_SHUKATSU_DISTILL}/Sources/Web"
VAULT_SHUKATSU_SOZAI_SELF="${VAULT_SHUKATSU_DISTILL}/Sources/Self"
VAULT_SHUKATSU_CHISHIKI="${VAULT_SHUKATSU_DISTILL}/Knowledge"
VAULT_SHUKATSU_HIKAKU_LOG="${VAULT_SHUKATSU_DISTILL}/CritiqueLog"

# 报告落点（可选）
VAULT_STOCK_REPORTS="${VAULT_ROOT}/Reports/Stocks"
VAULT_KIGYOU_REPORTS="${VAULT_ROOT}/Reports/Companies"
