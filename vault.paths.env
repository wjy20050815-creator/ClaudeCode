# Vault 路径注册表 — 所有 vault 路径的唯一定义处（router 模式）
# 用法：
#   shell：source 本文件（支持 ${VAR} 展开）
#   python：tools/vault_paths.py 的 vault_path("KEY")
#   skill（markdown 指令）：先读本文件解析路径，不要硬编码
# vault 重组时只改这里，然后跑 launchd-auditor / tools/vault_index_sync.py --check 验证。

VAULT_ROOT="/Users/jiayi/Documents/Obsidian Vault"

# 治理基础设施
VAULT_INDEX="${VAULT_ROOT}/index.md"
VAULT_LOG="${VAULT_ROOT}/log.md"
VAULT_MANUAL="${VAULT_ROOT}/_CLAUDE.md"
VAULT_ATTACHMENTS="${VAULT_ROOT}/_attachments"

# agent 写入点
VAULT_BRIEF_DIR="${VAULT_ROOT}/每日思维启发简报"
VAULT_INBOX="${VAULT_ROOT}/Inbox"
VAULT_PAPERS="${VAULT_ROOT}/ゼミ发表/Papers"
VAULT_CONCEPTS="${VAULT_ROOT}/ゼミ发表/Concepts"

# 就活蒸馏系统（2026-06-07 迁入 就活/知识库/）
VAULT_SHUKATSU_DISTILL="${VAULT_ROOT}/就活/知识库/_蒸馏システム"
VAULT_SHUKATSU_SOZAI_YT="${VAULT_SHUKATSU_DISTILL}/素材/YouTube"
VAULT_SHUKATSU_SOZAI_WEB="${VAULT_SHUKATSU_DISTILL}/素材/就活サイト"
VAULT_SHUKATSU_SOZAI_SELF="${VAULT_SHUKATSU_DISTILL}/素材/本人"
VAULT_SHUKATSU_CHISHIKI="${VAULT_SHUKATSU_DISTILL}/蒸馏知識/内定之路"
VAULT_SHUKATSU_HIKAKU_LOG="${VAULT_SHUKATSU_DISTILL}/批改ログ"

# 报告落点
VAULT_STOCK_REPORTS="${VAULT_ROOT}/投资/个别企业深度研究报告"
VAULT_KIGYOU_REPORTS="${VAULT_ROOT}/就活/企業分析报告"
