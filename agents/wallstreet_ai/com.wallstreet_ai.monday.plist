<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wallstreet_ai.monday</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__REPO_ROOT__/agents/wallstreet_ai/run.sh</string>
        <string>monday</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>__REPO_ROOT__/agents/wallstreet_ai/wallstreet_ai.log</string>
    <key>StandardErrorPath</key>
    <string>__REPO_ROOT__/agents/wallstreet_ai/wallstreet_ai.log</string>
</dict>
</plist>
